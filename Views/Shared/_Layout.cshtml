<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Buysimu Technology</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <style>
        :root {
            --bs-primary: #1a1a2e;
            --buysimu-gold: #f4a623;
            --buysimu-dark: #1a1a2e;
            --buysimu-mid: #16213e;
        }

        body { background: #f0f2f5; font-family: 'Segoe UI', sans-serif; }

        .sidebar {
            width: 260px;
            min-height: 100vh;
            background: var(--buysimu-dark);
            position: fixed;
            top: 0; left: 0;
            z-index: 100;
            padding-top: 0;
        }

        .sidebar-brand {
            background: var(--buysimu-mid);
            padding: 20px 24px;
            border-bottom: 2px solid var(--buysimu-gold);
        }

        .sidebar-brand h5 {
            color: var(--buysimu-gold);
            font-weight: 800;
            font-size: 1rem;
            margin: 0;
            letter-spacing: 1px;
        }

        .sidebar-brand small {
            color: rgba(255,255,255,0.5);
            font-size: 0.7rem;
        }

        .sidebar .nav-link {
            color: rgba(255,255,255,0.7);
            padding: 12px 24px;
            border-radius: 0;
            font-size: 0.88rem;
            transition: all 0.2s;
            border-left: 3px solid transparent;
        }

        .sidebar .nav-link:hover,
        .sidebar .nav-link.active {
            color: #fff;
            background: rgba(244,166,35,0.1);
            border-left-color: var(--buysimu-gold);
        }

        .sidebar .nav-link i { margin-right: 10px; font-size: 1rem; }

        .main-content {
            margin-left: 260px;
            min-height: 100vh;
        }

        .topbar {
            background: #fff;
            border-bottom: 1px solid #e0e0e0;
            padding: 14px 28px;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .topbar h6 { margin: 0; font-weight: 600; color: var(--buysimu-dark); }

        .content-area { padding: 28px; }

        .stat-card {
            border-radius: 12px;
            border: none;
            padding: 24px;
            color: #fff;
            position: relative;
            overflow: hidden;
        }

        .stat-card .icon {
            font-size: 2.5rem;
            opacity: 0.2;
            position: absolute;
            right: 20px;
            top: 20px;
        }

        .stat-card h2 { font-size: 2.2rem; font-weight: 800; margin: 0; }
        .stat-card p { margin: 0; opacity: 0.85; font-size: 0.9rem; }

        .card { border-radius: 12px; border: none; box-shadow: 0 2px 12px rgba(0,0,0,0.06); }
        .card-header { border-radius: 12px 12px 0 0 !important; font-weight: 600; }

        .badge-pending { background: #fff3cd; color: #856404; }
        .badge-checkedin { background: #d1e7dd; color: #0f5132; }
        .badge-removed { background: #f8d7da; color: #842029; }

        .btn-buysimu {
            background: var(--buysimu-gold);
            color: #1a1a2e;
            font-weight: 700;
            border: none;
        }

        .btn-buysimu:hover { background: #e09615; color: #1a1a2e; }

        .ticket-card {
            border: 2px dashed var(--buysimu-gold);
            border-radius: 12px;
            padding: 20px;
            background: #fffdf5;
        }

        .nav-section {
            padding: 12px 24px 4px;
            font-size: 0.7rem;
            color: rgba(255,255,255,0.3);
            text-transform: uppercase;
            letter-spacing: 1px;
        }
    </style>
</head>
<body>

@if (ViewData["HideSidebar"] == null)
{
    <div class="sidebar">
        <div class="sidebar-brand">
            <h5><i class="bi bi-shield-check"></i> BUYSIMU</h5>
            <small>TECHNOLOGY — Event Management</small>
        </div>
        <nav class="mt-3">
            <div class="nav-section">Main</div>
            <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Index" && ViewContext.RouteData.Values["controller"]?.ToString() == "Admin" ? "active" : "")"
               href="/admin">
                <i class="bi bi-speedometer2"></i> Dashboard
            </a>
            <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Merchants" ? "active" : "")"
               href="/admin/merchants">
                <i class="bi bi-building"></i> Merchants
            </a>
            <div class="nav-section">Operations</div>
            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Gate" ? "active" : "")"
               href="/gate">
                <i class="bi bi-qr-code-scan"></i> Gate Validation
            </a>
            <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "AuditLogs" ? "active" : "")"
               href="/admin/auditlogs">
                <i class="bi bi-journal-text"></i> Audit Logs
            </a>
        </nav>
    </div>
}

<div class="@(ViewData["HideSidebar"] == null ? "main-content" : "")">
    @if (ViewData["HideSidebar"] == null)
    {
        <div class="topbar">
            <h6>@ViewData["Title"]</h6>
            <span style="font-size:0.8rem;color:#999;">
                <i class="bi bi-calendar-event"></i> Buysimu Dinner Event
            </span>
        </div>
    }

    <div class="@(ViewData["HideSidebar"] == null ? "content-area" : "")">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="bi bi-exclamation-circle me-2"></i>@TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @RenderBody()
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
