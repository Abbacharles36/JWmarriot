@model List<BuysimTechnology.Models.AuditLog>
@{
    ViewData["Title"] = "Audit Logs";
}

<div class="card">
    <div class="card-header" style="background:#1a1a2e;color:#fff;">
        <i class="bi bi-journal-text me-2"></i>Full Audit Trail
    </div>
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Time</th>
                    <th>Merchant</th>
                    <th>Action</th>
                    <th>Details</th>
                    <th>Performed By</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var log in Model)
                {
                    <tr>
                        <td>
                            <small>
                                @log.Timestamp.ToString("dd MMM yyyy")<br/>
                                <strong>@log.Timestamp.ToString("HH:mm:ss")</strong>
                            </small>
                        </td>
                        <td>@log.Merchant?.Name</td>
                        <td>
                            <span class="badge @(log.Action == "CheckedIn" ? "badge-checkedin" :
                                               log.Action == "GuestRemoved" ? "badge-removed" :
                                               "badge-pending")">
                                @log.Action
                            </span>
                        </td>
                        <td><small>@log.Details</small></td>
                        <td><small>@log.PerformedBy</small></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
